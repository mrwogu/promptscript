{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Create|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "prs hook pre-edit",
            "timeout": 5,
            "statusMessage": "PromptScript: checking generated files..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Create|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "prs hook post-edit",
            "timeout": 15,
            "statusMessage": "PromptScript: compiling..."
          }
        ]
      },
      {
        "matcher": "Create|Edit|Execute",
        "hooks": [
          {
            "type": "command",
            "command": "cat >/dev/null || true; git rev-parse --git-dir >/dev/null 2>&1 && code-review-graph update --skip-flows --repo \"$(pwd)\" || true",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cat >/dev/null || true; git rev-parse --git-dir >/dev/null 2>&1 && code-review-graph status --repo \"$(pwd)\" || echo 'Not a git repo, skipping'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
