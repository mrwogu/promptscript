{
  "name": "@promptscript/source",
  "version": "1.10.0",
  "license": "MIT",
  "homepage": "https://getpromptscript.dev/",
  "scripts": {
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "typecheck": "pnpm nx run-many -t typecheck",
    "schema:generate": "ts-node --esm scripts/generate-schema.mts",
    "schema:check": "./scripts/check-schema.sh",
    "docs:serve": "PYTHONPATH=. mkdocs serve",
    "docs:build": "PYTHONPATH=. mkdocs build --strict",
    "docs:generate": "typedoc",
    "playground:serve": "nx serve playground",
    "playground:links": "ts-node --esm scripts/add-playground-links.mts",
    "docs:validate": "node --import @swc-node/register/esm-register scripts/validate-docs-examples.mts",
    "docs:validate:check": "node --import @swc-node/register/esm-register scripts/validate-docs-examples.mts --check",
    "docs:formatters": "node --import @swc-node/register/esm-register scripts/generate-formatter-docs.mts && npx prettier --write docs/reference/formatters/*.md",
    "docs:formatters:check": "node --import @swc-node/register/esm-register scripts/generate-formatter-docs.mts && npx prettier --write docs/reference/formatters/*.md && git diff --exit-code docs/reference/formatters/",
    "prs": "node --import @swc-node/register/esm-register packages/cli/src/cli.ts",
    "skill:sync": "./scripts/sync-skill.sh",
    "skill:check": "./scripts/sync-skill.sh --check",
    "grammar:check": "node --import @swc-node/register/esm-register scripts/check-grammar.mts",
    "vscode:package": "nx package vscode",
    "vscode:publish": "nx publish vscode",
    "prepare": "husky"
  },
  "private": true,
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@nx/esbuild": "22.6.3",
    "@nx/eslint": "22.6.3",
    "@nx/eslint-plugin": "22.6.3",
    "@nx/js": "22.6.3",
    "@nx/vite": "22.6.3",
    "@nx/vitest": "22.6.3",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.21",
    "@swc/helpers": "~0.5.21",
    "@types/node": "25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsonc-eslint-parser": "^3.1.0",
    "lz-string": "^1.5.0",
    "nx": "22.6.3",
    "path-browserify": "^1.0.1",
    "prettier": "~3.8.1",
    "ts-json-schema-generator": "^2.9.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.3.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "~5.9.3",
    "verdaccio": "^6.3.2",
    "vite": "^7.0.0",
    "vitest": "^4.1.2",
    "yaml": "^2.8.3"
  },
  "nx": {
    "includedScripts": []
  }
}
